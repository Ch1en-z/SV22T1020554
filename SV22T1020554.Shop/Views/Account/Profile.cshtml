@model Customer
@{
    ViewData["Title"] = "Thông tin cá nhân";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var provinces = ViewBag.Provinces as List<Province> ?? new List<Province>();
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="profile-card">
                <div class="profile-header">
                    <div class="profile-avatar">
                        @(Model.CustomerName?.Substring(0, 1).ToUpper())
                    </div>
                    <h4 class="mb-1">@Model.CustomerName</h4>
                    <p class="mb-0" style="opacity: 0.7;">@Model.Email</p>
                </div>
                <div class="profile-body">
                    @if (ViewBag.SuccessMessage != null)
                    {
                        <div class="alert alert-success alert-custom">
                            <i class="fas fa-check-circle me-2"></i>@ViewBag.SuccessMessage
                        </div>
                    }
                    @if (ViewBag.ErrorMessage != null)
                    {
                        <div class="alert alert-danger alert-custom">
                            <i class="fas fa-exclamation-circle me-2"></i>@ViewBag.ErrorMessage
                        </div>
                    }

                    <form method="post" asp-controller="Account" asp-action="Profile">
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="form-label fw-semibold">Tên khách hàng *</label>
                                <input type="text" class="form-control" name="customerName"
                                       value="@Model.CustomerName" required style="border-radius: 8px;" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-semibold">Tên giao dịch</label>
                                <input type="text" class="form-control" name="contactName"
                                       value="@Model.ContactName" style="border-radius: 8px;" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-semibold">Email</label>
                                <input type="email" class="form-control" value="@Model.Email"
                                       disabled style="border-radius: 8px; background: #f8fafc;" />
                                <input type="hidden" name="email" value="@Model.Email" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-semibold">Điện thoại</label>
                                <input type="tel" class="form-control" name="phone"
                                       value="@Model.Phone" style="border-radius: 8px;" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-semibold">Tỉnh/Thành</label>
                                <select class="form-select" name="province" style="border-radius: 8px;">
                                    <option value="">-- Chọn tỉnh/thành --</option>
                                    @foreach (var p in provinces)
                                    {
                                        if (Model.Province == p.ProvinceName)
                                        {
                                            <option value="@p.ProvinceName" selected>@p.ProvinceName</option>
                                        }
                                        else
                                        {
                                            <option value="@p.ProvinceName">@p.ProvinceName</option>
                                        }
                                    }
                                </select>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-semibold">Địa chỉ</label>
                                <input type="text" class="form-control" name="address"
                                       value="@Model.Address" style="border-radius: 8px;" />
                            </div>
                        </div>

                        <div class="d-flex gap-2 mt-4">
                            <button type="submit" class="btn btn-primary-custom">
                                <i class="fas fa-save me-1"></i>Lưu thay đổi
                            </button>
                            <a asp-controller="Account" asp-action="ChangePassword" class="btn btn-outline-custom">
                                <i class="fas fa-key me-1"></i>Đổi mật khẩu
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
