@{
    ViewData["Title"] = "Trang chủ";
}

<!-- Hero Section -->
<section class="hero-section">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-lg-6" style="position: relative; z-index: 2;">
                <h1>
                    Mua sắm thông minh<br />
                    với <span>BHQCShop</span>
                </h1>
                <p class="mb-4">
                    Khám phá hàng ngàn sản phẩm chất lượng với giá tốt nhất.
                    Giao hàng nhanh chóng, thanh toán tiện lợi.
                </p>
                <a asp-controller="Product" asp-action="Index" class="btn btn-hero">
                    <i class="fas fa-shopping-bag me-2"></i>Khám phá ngay
                </a>
            </div>
            <div class="col-lg-6 text-center d-none d-lg-block" style="position: relative; z-index: 2;">
                <i class="fas fa-store" style="font-size: 12rem; opacity: 0.15; color: #818cf8;"></i>
            </div>
        </div>
    </div>
</section>

<!-- Categories Section -->
@if (ViewBag.Categories != null)
{
    var categories = ViewBag.Categories as List<Category>;
    if (categories != null && categories.Count > 0)
    {
        <section class="py-5">
            <div class="container">
                <h2 class="section-title">Danh mục sản phẩm</h2>
                <div class="row g-3">
                    @foreach (var cat in categories)
                    {
                        <div class="col-6 col-md-4 col-lg-2">
                            <a asp-controller="Product" asp-action="Index" asp-route-categoryID="@cat.CategoryID" style="text-decoration: none;">
                                <div class="category-card">
                                    <div class="category-icon">
                                        <i class="fas fa-tag"></i>
                                    </div>
                                    <div class="category-name">@cat.CategoryName</div>
                                </div>
                            </a>
                        </div>
                    }
                </div>
            </div>
        </section>
    }
}

<!-- Featured Products Section -->
@if (ViewBag.FeaturedProducts != null)
{
    var products = ViewBag.FeaturedProducts as List<Product>;
    if (products != null && products.Count > 0)
    {
        <section class="py-5" style="background: #fff;">
            <div class="container">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <h2 class="section-title mb-0">Sản phẩm nổi bật</h2>
                    <a asp-controller="Product" asp-action="Index" class="btn btn-outline-custom">
                        Xem tất cả <i class="fas fa-arrow-right ms-1"></i>
                    </a>
                </div>
                <div class="row g-4">
                    @foreach (var p in products)
                    {
                        <div class="col-6 col-md-4 col-lg-3">
                            <div class="product-card">
                                <a asp-controller="Product" asp-action="Detail" asp-route-id="@p.ProductID">
                                    <div class="product-image">
                                        @if (!string.IsNullOrEmpty(p.Photo))
                                        {
                                            <img src="@p.Photo" alt="@p.ProductName" />
                                        }
                                        else
                                        {
                                            <i class="fas fa-image" style="font-size: 3rem; color: #cbd5e1;"></i>
                                        }
                                    </div>
                                </a>
                                <div class="product-body">
                                    <a asp-controller="Product" asp-action="Detail" asp-route-id="@p.ProductID" class="product-name">
                                        @p.ProductName
                                    </a>
                                    <div class="product-price">
                                        @p.Price.ToString("N0") ₫
                                        <span class="product-unit">/ @p.Unit</span>
                                    </div>
                                    <button type="button" class="btn btn-add-cart" onclick="openAddToCartModal(@p.ProductID)">
                                        <i class="fas fa-cart-plus me-1"></i>Thêm vào giỏ
                                    </button>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </section>
    }
}
