<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - BHQCShop</title>
    <meta name="description" content="BHQCShop - Cửa hàng trực tuyến hàng đầu" />

    <!-- Google Font -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />

    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />

    <!-- Bootstrap CSS -->
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />

    <!-- Custom CSS -->
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <!-- Navbar -->
    <nav class="navbar navbar-expand-lg shop-navbar">
        <div class="container">
            <a class="navbar-brand" asp-controller="Home" asp-action="Index">
                <i class="fas fa-store me-2"></i>BHQCShop
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#shopNavbar"
                    aria-controls="shopNavbar" aria-expanded="false" aria-label="Toggle navigation"
                    style="border-color: rgba(255,255,255,0.2);">
                <i class="fas fa-bars" style="color: rgba(255,255,255,0.8);"></i>
            </button>
            <div class="collapse navbar-collapse" id="shopNavbar">
                <ul class="navbar-nav me-auto">
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Home" asp-action="Index">
                            <i class="fas fa-home me-1"></i>Trang chủ
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Product" asp-action="Index">
                            <i class="fas fa-th-large me-1"></i>Sản phẩm
                        </a>
                    </li>
                    @if (User.Identity != null && User.Identity.IsAuthenticated)
                    {
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Order" asp-action="Index">
                                <i class="fas fa-clipboard-list me-1"></i>Đơn hàng
                            </a>
                        </li>
                    }
                </ul>
                <ul class="navbar-nav">
                    <li class="nav-item">
                        <a class="nav-link position-relative" asp-controller="Order" asp-action="Cart">
                            <i class="fas fa-shopping-cart me-1"></i>Giỏ hàng
                            <span class="cart-badge" id="cartBadge">0</span>
                        </a>
                    </li>
                    @if (User.Identity != null && User.Identity.IsAuthenticated)
                    {
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle navbar-user" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                <span class="user-avatar">
                                    @(User.Identity.Name?.Substring(0, 1).ToUpper())
                                </span>
                                <span class="d-none d-md-inline">@User.Identity.Name</span>
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end" style="border-radius: 10px; box-shadow: 0 10px 30px rgba(0,0,0,0.15); border: none; margin-top: 0.5rem;">
                                <li>
                                    <a class="dropdown-item py-2" asp-controller="Account" asp-action="Profile">
                                        <i class="fas fa-user me-2 text-primary"></i>Thông tin cá nhân
                                    </a>
                                </li>
                                <li>
                                    <a class="dropdown-item py-2" asp-controller="Account" asp-action="ChangePassword">
                                        <i class="fas fa-key me-2 text-warning"></i>Đổi mật khẩu
                                    </a>
                                </li>
                                <li>
                                    <a class="dropdown-item py-2" asp-controller="Order" asp-action="Index">
                                        <i class="fas fa-box me-2 text-info"></i>Lịch sử đơn hàng
                                    </a>
                                </li>
                                <li><hr class="dropdown-divider" /></li>
                                <li>
                                    <a class="dropdown-item py-2 text-danger" asp-controller="Account" asp-action="Logout">
                                        <i class="fas fa-sign-out-alt me-2"></i>Đăng xuất
                                    </a>
                                </li>
                            </ul>
                        </li>
                    }
                    else
                    {
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Account" asp-action="Login">
                                <i class="fas fa-sign-in-alt me-1"></i>Đăng nhập
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Account" asp-action="Register">
                                <i class="fas fa-user-plus me-1"></i>Đăng ký
                            </a>
                        </li>
                    }
                </ul>
            </div>
        </div>
    </nav>

    <!-- Main Content -->
    <main>
        @RenderBody()
    </main>

    <!-- Footer -->
    <footer class="shop-footer">
        <div class="container">
            <div class="row">
                <div class="col-lg-4 mb-4 mb-lg-0">
                    <h5><span class="footer-brand"><i class="fas fa-store me-2"></i>BHQCShop</span></h5>
                    <p class="mb-0" style="font-size: 0.9rem;">Cửa hàng trực tuyến với đa dạng sản phẩm chất lượng cao, giá cả hợp lý.</p>
                </div>
                <div class="col-lg-3 mb-4 mb-lg-0">
                    <h5>Liên kết</h5>
                    <ul class="list-unstyled">
                        <li class="mb-2"><a asp-controller="Home" asp-action="Index"><i class="fas fa-chevron-right me-1" style="font-size:0.7rem;"></i>Trang chủ</a></li>
                        <li class="mb-2"><a asp-controller="Product" asp-action="Index"><i class="fas fa-chevron-right me-1" style="font-size:0.7rem;"></i>Sản phẩm</a></li>
                        <li class="mb-2"><a asp-controller="Order" asp-action="Cart"><i class="fas fa-chevron-right me-1" style="font-size:0.7rem;"></i>Giỏ hàng</a></li>
                    </ul>
                </div>
                <div class="col-lg-3 mb-4 mb-lg-0">
                    <h5>Tài khoản</h5>
                    <ul class="list-unstyled">
                        <li class="mb-2"><a asp-controller="Account" asp-action="Login"><i class="fas fa-chevron-right me-1" style="font-size:0.7rem;"></i>Đăng nhập</a></li>
                        <li class="mb-2"><a asp-controller="Account" asp-action="Register"><i class="fas fa-chevron-right me-1" style="font-size:0.7rem;"></i>Đăng ký</a></li>
                        <li class="mb-2"><a asp-controller="Order" asp-action="Index"><i class="fas fa-chevron-right me-1" style="font-size:0.7rem;"></i>Đơn hàng</a></li>
                    </ul>
                </div>
                <div class="col-lg-2">
                    <h5>Liên hệ</h5>
                    <ul class="list-unstyled" style="font-size: 0.9rem;">
                        <li class="mb-2"><i class="fas fa-phone me-2"></i>0123 456 789</li>
                        <li class="mb-2"><i class="fas fa-envelope me-2"></i>info&#64;litecommerce.vn</li>
                    </ul>
                </div>
            </div>
            <div class="footer-bottom">
                &copy; 2026 BHQCShop - SV22T1020554. All rights reserved.
            </div>
        </div>
    </footer>

    <!-- Add to Cart Modal (shared) -->
    @await Html.PartialAsync("_AddToCartModal")

    <!-- Scripts -->
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    <script>
        // Update cart badge
        function updateCartBadge() {
            $.get('/Order/GetCartCount', function(data) {
                var badge = $('#cartBadge');
                badge.text(data.count);
                if (data.count > 0) {
                    badge.show();
                } else {
                    badge.hide();
                }
            });
        }

        // ========== Modal Add to Cart ==========
        function modalIncreaseQty() {
            var input = document.getElementById('modalQuantity');
            input.value = parseInt(input.value) + 1;
        }
        function modalDecreaseQty() {
            var input = document.getElementById('modalQuantity');
            if (parseInt(input.value) > 1) {
                input.value = parseInt(input.value) - 1;
            }
        }

        // Mở modal thêm giỏ hàng
        function openAddToCartModal(productID, actionType = 'both') {
            // Reset modal
            $('#modalLoading').show();
            $('#modalProductInfo').hide();
            $('#modalQuantity').val(1);
            $('input[name="modalColor"]').prop('checked', false);
            $('input[name="modalSize"]').prop('checked', false);
            $('#modalColorGroup').hide();
            $('#modalSizeGroup').hide();

            if (actionType === 'buy') {
                $('#btnConfirmAddToCart').hide();
                $('#btnBuyNow').show();
            } else if (actionType === 'cart') {
                $('#btnConfirmAddToCart').show();
                $('#btnBuyNow').hide();
            } else {
                $('#btnConfirmAddToCart').show();
                $('#btnBuyNow').show();
            }

            var modal = new bootstrap.Modal(document.getElementById('addToCartModal'));
            modal.show();

            // Lấy thông tin sản phẩm
            $.get('/Order/GetProductInfo', { productID: productID }, function (data) {
                if (data.success) {
                    $('#modalProductID').val(data.productID);
                    $('#modalProductName').text(data.productName);
                    $('#modalProductPrice').text(data.price.toLocaleString('vi-VN') + ' ₫ / ' + data.unit);

                    if (data.photo) {
                        $('#modalProductImage').attr('src', data.photo).show();
                    } else {
                        $('#modalProductImage').hide();
                    }

                    if (data.categoryName) {
                        $('#modalCategoryName').text(data.categoryName).show();
                    } else {
                        $('#modalCategoryName').hide();
                    }

                    // Hiển thị chọn màu
                    if (data.needColor) {
                        $('#modalColorGroup').show();
                    }

                    // Hiển thị chọn size
                    if (data.needSize) {
                        $('#modalSizeGroup').show();
                    }

                    $('#modalLoading').hide();
                    $('#modalProductInfo').show();
                } else {
                    alert('Không thể tải thông tin sản phẩm');
                    bootstrap.Modal.getInstance(document.getElementById('addToCartModal')).hide();
                }
            }).fail(function () {
                alert('Lỗi kết nối');
                bootstrap.Modal.getInstance(document.getElementById('addToCartModal')).hide();
            });
        }

        // Xác nhận thao tác chung
        function submitFormAddToCart(isBuyNow) {
            var productID = $('#modalProductID').val();
            var quantity = parseInt($('#modalQuantity').val()) || 1;
            var color = $('input[name="modalColor"]:checked').val() || '';
            var size = $('input[name="modalSize"]:checked').val() || '';

            $.ajax({
                url: '/Order/AddToCart',
                type: 'POST',
                data: {
                    productID: productID,
                    quantity: quantity,
                    color: color,
                    size: size
                },
                success: function (response) {
                    if (response.success) {
                        // Đóng modal
                        bootstrap.Modal.getInstance(document.getElementById('addToCartModal')).hide();

                        // Cập nhật badge giỏ hàng
                        var badge = $('#cartBadge');
                        badge.text(response.count);
                        if (response.count > 0) {
                            badge.show();
                        }

                        if (isBuyNow) {
                            // Chuyển hướng sang Checkout
                            var form = $('<form action="/Order/CheckoutSelected" method="POST"></form>');
                            form.append('<input type="hidden" name="selectedProductIDs" value="' + productID + '" />');
                            $('body').append(form);
                            form.submit();
                        } else {
                            // Tự động sửa lỗi hiển thị tiếng Việt nếu Server trả về chuỗi bị lỗi
                            var msg = response.message || "";
                            msg = msg.replace("Đ? thêm vào gi? hàng!", "Đã thêm vào giỏ hàng!");
                            
                            // Toast thành công
                            $('#cartToastMsg').text(msg);
                            var toast = new bootstrap.Toast(document.getElementById('cartToast'));
                            toast.show();
                        }
                    } else {
                        alert("Lỗi: " + response.message);
                    }
                },
                error: function (xhr) {
                    if (xhr.status === 401) {
                        bootstrap.Modal.getInstance(document.getElementById('addToCartModal')).hide();
                        alert("Vui lòng đăng nhập để sử dụng tính năng này!");
                        window.location.href = '/Account/Login';
                    } else {
                        alert("Hệ thống gặp sự cố, vui lòng thử lại sau.");
                    }
                }
            });
        }

        // Xác nhận thêm vào giỏ
        $('#btnConfirmAddToCart').on('click', function () {
            submitFormAddToCart(false);
        });

        // Xác nhận mua ngay
        $('#btnBuyNow').on('click', function () {
            submitFormAddToCart(true);
        });

        // Legacy function for backward compatibility
        function addToCart(productID) {
            openAddToCartModal(productID);
        }

        $(document).ready(function () {
            updateCartBadge();
        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
