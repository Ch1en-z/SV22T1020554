@{
    // Tự động nhận diện xem đây là request AJAX (mở modal) hay truy cập trực tiếp
    bool isAjax = Context.Request.Headers["X-Requested-With"] == "XMLHttpRequest";
    Layout = isAjax ? null : "_Layout";
    ViewBag.Title = "Xác nhận chuyển giao hàng";
}

@if (!isAjax)
{
    @* Giao diện khi truy cập trực tiếp (nguyên trang) *@
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-5">
            <div class="card card-outline card-navy shadow-lg mt-4 animated fadeIn">
                @await Html.PartialAsync("_ShippingForm")
            </div>
            <div class="text-center mt-3">
                <a href="~/Order" class="btn btn-link text-decoration-none text-muted">
                    <i class="bi bi-arrow-left"></i> Quay lại danh sách đơn hàng
                </a>
            </div>
        </div>
    </div>
}
else
{
    @* Giao diện khi mở trong modal *@
    @await Html.PartialAsync("_ShippingForm")
}

@section Styles {
    <style>
        .animated { animation-duration: 0.5s; animation-fill-mode: both; }
        @@keyframes fadeIn { from { opacity: 0; transform: translateY(20px); } to { opacity: 1; transform: translateY(0); } }
        .fadeIn { animation-name: fadeIn; }
    </style>
}
