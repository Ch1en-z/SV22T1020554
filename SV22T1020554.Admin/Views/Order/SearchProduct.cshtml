@model SV22T1020554.Models.Common.PagedResult<SV22T1020554.Models.Catalog.Product>
@{
    Layout = null;
}
@if (Model.DataItems.Any())
{
    <!-- Danh sách ghim cuộn -->
    <div style="max-height: 540px; overflow-y: auto; overflow-x: hidden; padding-right: 5px;">
        @foreach (var item in Model.DataItems)
        {
            <form action="~/Order/AddToCart" method="post" class="form-add-to-cart mb-2">
                <input type="hidden" name="ProductID" value="@item.ProductID" />
                <input type="hidden" name="ProductName" value="@item.ProductName" />
                <input type="hidden" name="Unit" value="@item.Unit" />
                <input type="hidden" name="Photo" value="@item.Photo" />

                <div class="row pt-1 pb-1 border-bottom">
                    <div class="col-sm-2 text-center align-self-center">
                        <img src="@(string.IsNullOrEmpty(item.Photo) ? Url.Content("~/images/products/no-image.png") : Url.Content($"~/images/products/{item.Photo}"))"
                             class="img-fluid" style="width: auto; max-height: 50px;" alt="@item.ProductName">
                    </div>
                    <div class="col-sm-6 align-self-center">
                        <div style="font-weight: 500;">@item.ProductName</div>
                        <div class="text-muted small">Mã: @item.ProductID | ĐVT: @item.Unit</div>
                    </div>
                    <div class="col-sm-4 align-self-center text-end">
                        <div class="input-group input-group-sm">
                            <span class="input-group-text fw-bold">@item.Price.ToString("N0")</span>
                            <input type="number" class="form-control text-center" name="Quantity" min="1" value="1" style="max-width: 60px;">
                            <input type="hidden" name="SalePrice" value="@item.Price" />
                            <button type="submit" class="btn btn-sm btn-primary">
                                <i class="bi bi-cart-plus"></i>
                            </button>
                        </div>
                    </div>
                </div>
            </form>
        }
    </div>

    @if (Model.PageCount > 1)
    {
        <ul class="pagination pagination-sm justify-content-center mt-3 mb-0">
            <li class="page-item @(Model.Page == 1 ? "disabled" : "")">
                <a class="page-link" href="javascript:;" onclick="doSearchProduct(@(Model.Page - 1))"><i class="bi bi-chevron-left"></i></a>
            </li>
            
            @{
                int startPage = Math.Max(1, Model.Page - 2);
                int endPage = Math.Min(Model.PageCount, Model.Page + 2);
                
                if (startPage > 1) {
                    <li class="page-item"><a class="page-link" href="javascript:;" onclick="doSearchProduct(1)">1</a></li>
                    if (startPage > 2) {
                        <li class="page-item disabled"><span class="page-link">...</span></li>
                    }
                }

                for (int i = startPage; i <= endPage; i++) {
                    if (i == Model.Page) {
                        <li class="page-item active"><span class="page-link">@i</span></li>
                    } else {
                        <li class="page-item"><a class="page-link" href="javascript:;" onclick="doSearchProduct(@i)">@i</a></li>
                    }
                }

                if (endPage < Model.PageCount) {
                    if (endPage < Model.PageCount - 1) {
                        <li class="page-item disabled"><span class="page-link">...</span></li>
                    }
                    <li class="page-item"><a class="page-link" href="javascript:;" onclick="doSearchProduct(@Model.PageCount)">@Model.PageCount</a></li>
                }
            }

            <li class="page-item @(Model.Page == Model.PageCount ? "disabled" : "")">
                <a class="page-link" href="javascript:;" onclick="doSearchProduct(@(Model.Page + 1))"><i class="bi bi-chevron-right"></i></a>
            </li>
        </ul>
    }
}
else
{
    <div class="alert alert-info text-center mt-2">
        <i class="bi bi-info-circle"></i> Không tìm thấy mặt hàng nào phù hợp.
    </div>
}

