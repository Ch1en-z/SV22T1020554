@model Employee
@{
}

<div class="card card-primary card-outline">
    <div class="card-header">
        <h3 class="card-title">@ViewBag.Title</h3>
    </div>

    <div class="card-body">
        <form asp-controller="Employee" asp-action="Save" method="post" enctype="multipart/form-data">
            <input type="hidden" asp-for="EmployeeID" />

            <div class="row mb-3">
                <label class="col-sm-2 col-form-label">Họ và tên:</label>
                <div class="col-sm-6">
                    <input type="text" asp-for="FullName" class="form-control" placeholder="Nhập họ tên nhân viên" autofocus />
                    @Html.ValidationMessageFor(m => m.FullName, "", new { @class = "text-danger" })
                </div>
                <label class="col-sm-2 col-form-label text-end">Ngày sinh:</label>
                <div class="col-sm-2">
                    <input type="text" name="birthDateInput" class="form-control date-picker" placeholder="Ngày sinh" value="@(Model.BirthDate?.ToString("dd/MM/yyyy"))" />
                    @Html.ValidationMessageFor(m => m.BirthDate, "", new { @class = "text-danger" })
                </div>
            </div>

            <div class="row mb-3">
                <label class="col-sm-2 col-form-label">Địa chỉ:</label>
                <div class="col-sm-10">
                    <textarea class="form-control" asp-for="Address" rows="2" placeholder="Nhập địa chỉ cư trú"></textarea>
                </div>
            </div>

            <div class="row mb-3">
                <label class="col-sm-2 col-form-label">Điện thoại:</label>
                <div class="col-sm-4">
                    <input type="tel" asp-for="Phone" class="form-control" placeholder="Số điện thoại cá nhân" />
                </div>
                <label class="col-sm-2 col-form-label text-end">Email:</label>
                <div class="col-sm-4">
                    <input type="email" asp-for="Email" class="form-control" placeholder="Địa chỉ email liên hệ" />
                    @Html.ValidationMessageFor(m => m.Email, "", new { @class = "text-danger" })
                </div>
            </div>

            <div class="row mb-3">
                <label class="col-sm-2 col-form-label">Trạng thái:</label>
                <div class="col-sm-10">
                    <div class="form-check form-switch mt-2">
                        <input class="form-check-input" asp-for="IsWorking" type="checkbox" id="IsWorking" />
                        <label class="form-check-label ms-2" for="IsWorking">Nhân viên này vẫn đang làm việc tại công ty</label>
                    </div>
                </div>
            </div>

            <div class="row mb-3">
                <label class="col-sm-2 col-form-label">Ảnh đại diện:</label>
                <div class="col-sm-10">
                    <input type="file" name="uploadPhoto" class="form-control mb-2" accept="image/*"
                           onchange="document.getElementById('imgPreview').src = window.URL.createObjectURL(this.files[0])" />
                    <input type="hidden" asp-for="Photo" />
                    <img id="imgPreview"
                         src="~/images/employees/@(string.IsNullOrEmpty(Model.Photo) ? "nophoto.png" : Model.Photo)"
                         class="img-fluid rounded border"
                         style="max-height: 180px; min-width: 120px;" />
                </div>
            </div>

            <div class="card-footer text-end mt-3">
                @if (Model.EmployeeID > 0)
                {
                    <a href="~/Employee/ChangePassword/@Model.EmployeeID" class="btn btn-warning float-start me-1">
                        <i class="bi bi-key me-1"></i> Đổi mật khẩu
                    </a>
                    <a href="~/Employee/ChangeRole/@Model.EmployeeID" class="btn btn-info float-start me-1">
                        <i class="bi bi-shield-check me-1"></i> Phân quyền
                    </a>
                }
                <button type="submit" class="btn btn-primary">
                    <i class="bi bi-save me-1"></i> Lưu dữ liệu
                </button>
                <a href="~/Employee" class="btn btn-default">
                    Quay lại
                </a>
            </div>
            <div asp-validation-summary="ModelOnly" class="text-danger mt-2 text-start"></div>
        </form>
    </div>
</div>

