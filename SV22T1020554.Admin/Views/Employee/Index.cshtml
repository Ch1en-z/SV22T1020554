@model PagedResult<Employee>
@{
    ViewBag.Title = "Quản lý Nhân viên";
}
@section PageToolBar {
    <a href="~/Employee/Create" class="btn btn-primary">
        <i class="bi bi-plus-circle me-1"></i>
        Bổ sung
    </a>
}

<div class="card mb-3">
    <div class="card-body">
        <form id="formSearch" action="~/Employee" method="get">
            <div class="input-group">
                <input type="text" name="searchValue"
                       class="form-control"
                       placeholder="Nhập tên nhân viên cần tìm" 
                       value="@ViewBag.SearchValue"
                       autofocus />
                <button class="btn btn-info" type="submit">
                    <i class="bi bi-search me-1"></i> Tìm kiếm
                </button>
            </div>
        </form>
    </div>
</div>

<div class="mb-2 text-muted">
    Danh sách có <strong>@Model.RowCount</strong> nhân viên. Trang <strong>@Model.Page / @Model.PageCount</strong>
</div>

<div class="card">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-striped table-hover table-bordered mb-0">
                <thead class="table-secondary">
                    <tr>
                        <th style="width: 80px;" class="text-center">Ảnh</th>
                        <th>Họ tên</th>
                        <th>Ngày sinh</th>
                        <th>Điện thoại</th>
                        <th>Email</th>
                        <th>Địa chỉ</th>
                        <th class="text-center" style="width:140px;">Trạng thái</th>
                        <th class="text-center" style="width:140px;">Thao tác</th>
                    </tr>
                </thead>
                <tbody class="align-middle">
                    @foreach (var item in Model.DataItems)
                    {
                        <tr>
                            <td class="text-center">
                                <img src="~/images/employees/@(string.IsNullOrEmpty(item.Photo) ? "nophoto.png" : item.Photo)" 
                                     alt="@item.FullName" 
                                     class="rounded border" 
                                     style="width: 45px; height: 45px; object-fit: cover;" />
                            </td>
                             <td>@item.FullName</td>
                            <td>@(item.BirthDate?.ToString("dd/MM/yyyy"))</td>
                            <td>@item.Phone</td>
                            <td>@item.Email</td>
                            <td class="text-truncate" style="max-width: 15rem;">@item.Address</td>
                            <td class="text-center">
                                @if (item.IsWorking == true)
                                {
                                    <span class="badge bg-success">Đang làm việc</span>
                                }
                                else
                                {
                                    <span class="badge bg-danger">Đã nghỉ việc</span>
                                }
                            </td>
                            <td class="text-center text-nowrap">
                                <a href="~/Employee/Edit/@item.EmployeeID" class="btn btn-sm btn-primary">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                <a href="~/Employee/Delete/@item.EmployeeID" class="btn btn-sm btn-danger">
                                    <i class="bi bi-trash"></i>
                                </a>
                                <a href="~/Employee/ChangePassword/@item.EmployeeID" class="btn btn-sm btn-warning">
                                    <i class="bi bi-key"></i>
                                </a>
                                <a href="~/Employee/ChangeRole/@item.EmployeeID" class="btn btn-sm btn-info">
                                    <i class="bi bi-shield-check"></i>
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    @if (Model.PageCount > 1)
    {
        <div class="card-footer">
            <ul class="pagination pagination-sm m-0 justify-content-center">
                @for (int i = 1; i <= Model.PageCount; i++)
                {
                    if (i == Model.Page)
                    {
                        <li class="page-item active"><span class="page-link">@i</span></li>
                    }
                    else
                    {
                        <li class="page-item"><a class="page-link" href="~/Employee?page=@i&searchValue=@ViewBag.SearchValue">@i</a></li>
                    }
                }
            </ul>
        </div>
    }
</div>



