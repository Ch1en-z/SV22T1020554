@model Customer
@{
    ViewBag.Title = "Thiết lập thông tin khách hàng";
}

<div class="card card-primary card-outline">
    <div class="card-header">
        <h3 class="card-title">@ViewBag.Title</h3>
    </div>

    <div class="card-body mt-2">
        <form asp-controller="Customer" asp-action="Save" method="post">
            <div class="row">
                <div class="col-md-6 form-group mb-3">
                    <label class="form-label" style="font-weight:bold">Tên khách hàng:</label>
                    <input type="text" class="form-control" name="CustomerName" placeholder="Họ và tên khách hàng" required autofocus>
                </div>

                <div class="col-md-6 form-group mb-3">
                    <label class="form-label" style="font-weight:bold">Tên giao dịch:</label>
                    <input type="text" class="form-control" name="ContactName" placeholder="Tên giao dịch">
                </div>
            </div>

            <div class="row">
                <div class="col-md-6 form-group mb-3">
                    <label class="form-label" style="font-weight:bold">Điện thoại:</label>
                    <input type="tel" class="form-control" name="Phone" placeholder="Số điện thoại di động">
                </div>

                <div class="col-md-6 form-group mb-3">
                    <label class="form-label" style="font-weight:bold">Email:</label>
                    <input type="email" class="form-control" name="Email" placeholder="địa_chỉ_email@gmail.com">
                </div>
            </div>

            <div class="row">
                <div class="col-md-6 form-group mb-3">
                    <label class="form-label" style="font-weight:bold">Địa chỉ:</label>
                    <input type="text" class="form-control" name="Address" placeholder="Số nhà, tên đường...">
                </div>

                <div class="col-md-6 form-group mb-3">
                    <label class="form-label" style="font-weight:bold">Tỉnh/Thành:</label>
                    <select class="form-select" name="Province">
                        <option value="">-- Chọn Tỉnh/Thành --</option>
                        <option value="Hà Nội">Hà Nội</option>
                        <option value="TP. Hồ Chí Minh">TP. Hồ Chí Minh</option>
                        <option value="Đà Nẵng">Đà Nẵng</option>
                    </select>
                </div>
            </div>

            <div class="form-group mb-3">
                <label class="form-label d-block" style="font-weight:bold">Trạng thái:</label>
                <div class="form-check form-check-inline">
                    <input class="form-check-input" type="radio" name="Status" id="active" value="true" checked>
                    <label class="form-check-label" for="active">Đang hoạt động</label>
                </div>
                <div class="form-check form-check-inline">
                    <input class="form-check-input" type="radio" name="Status" id="locked" value="false">
                    <label class="form-check-label" for="locked">Bị khóa</label>
                </div>
            </div>

            <div class="card-footer bg-white border-top mt-3 text-end px-0 pb-0 shadow-none border-0">
                <button type="submit" class="btn btn-primary">
                    <i class="bi bi-save me-1"></i> Lưu dữ liệu
                </button>
                <a href="~/Customer" class="btn btn-default">
                    Quay lại
                </a>
            </div>
        </form>
    </div>
</div>
