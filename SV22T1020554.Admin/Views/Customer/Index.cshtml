@using SV22T1020554.Models.Common
@using SV22T1020554.Models.Partner
@model PagedResult<Customer>

@{
    ViewBag.Title = "Quản lý Khách hàng";
}
@section PageToolBar {
    <a href="~/Customer/Create" class="btn btn-primary">
        <i class="bi bi-plus-circle me-1"></i>
        Bổ sung
    </a>
}
<div class="card mb-3">
    <div class="card-body">
        <form id="formSearch" method="get" action="/Customer">
            <div class="input-group">
                <input type="text"
                       class="form-control"
                       name="searchValue"
                       value="@ViewBag.SearchValue"
                       placeholder="Tên khách hàng..." autofocus />
                <button class="btn btn-info d-flex align-items-center" type="submit">
                    <i class="bi bi-search me-1"></i>
                </button>
            </div>
        </form>
    </div>
</div>

@if (TempData["Message"] != null)
{
    <div class="alert alert-warning alert-dismissible fade show" role="alert">
        <i class="bi bi-exclamation-triangle me-1"></i>
        @TempData["Message"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="mb-2 text-muted">
    Danh sách này có <strong>@Model.RowCount</strong> khách hàng
</div>

<div class="card">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-striped table-hover table-bordered mb-0">
                <thead class="table-secondary">
                    <tr>
                        <th>Tên khách hàng</th>
                        <th>Tên giao dịch</th>
                        <th>Điện thoại</th>
                        <th>Email</th>
                        <th>Địa chỉ</th>
                        <th>Tỉnh / Thành</th>
                        <th class="text-center" style="width:120px;">Trạng thái</th>
                        <th class="text-center" style="width:100px;">Thao tác</th>
                    </tr>
                </thead>
                <tbody class="align-middle">
                    @if (Model.DataItems != null && Model.DataItems.Count > 0)
                    {
                        @foreach (var item in Model.DataItems)
                        {
                            <tr>
                                <td>@item.CustomerName</td>
                                <td>@item.ContactName</td>
                                <td>@item.Phone</td>
                                <td>@item.Email</td>
                                <td>@item.Address</td>
                                <td>@item.Province</td>
                                <td class="text-center">
                                    @if (item.IsLocked == false || item.IsLocked == null)
                                    {
                                        <span class="badge bg-success">Hoạt động</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger">Bị khóa</span>
                                    }
                                </td>
                                <td class="text-center text-nowrap">
                                    <a href="~/Customer/Edit/@item.CustomerID" class="btn btn-sm btn-primary">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                    <a href="~/Customer/Delete/@item.CustomerID" class="btn btn-sm btn-danger">
                                        <i class="bi bi-trash"></i>
                                    </a>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="8" class="text-center text-muted py-3">
                                <i class="bi bi-inbox me-1"></i> Không tìm thấy khách hàng nào
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>


    @if (Model.PageCount > 1)
    {
        <div class="card-footer">
            <!-- Pagination -->
            <ul class="pagination justify-content-center mb-0">
                @foreach (var pageItem in Model.GetDisplayPages())
                {
                    if (pageItem.IsEllipsis)
                    {
                        <li class="page-item disabled">
                            <span class="page-link">...</span>
                        </li>
                    }
                    else
                    {
                        <li class="page-item @(pageItem.IsCurrent ? "active" : "")">
                            <a class="page-link" href="/Customer?page=@pageItem.Page">@pageItem.Page</a>
                        </li>
                    }
                }
            </ul>
        </div>
    }
</div>
