@using SV22T1020554.Models.Partner
@using SV22T1020554.Models.DataDictionary
@model Customer

@{
    if (string.IsNullOrEmpty(ViewBag.Title))
    {
        ViewBag.Title = Model.CustomerID == 0 ? "Bổ sung khách hàng" : "Chỉnh sửa khách hàng";
    }
    var provinces = ViewBag.Provinces as List<Province> ?? new List<Province>();
}

@section PageToolBar {
    <button type="submit" form="formEdit" class="btn btn-primary">
        <i class="bi bi-save"></i>
        Lưu dữ liệu
    </button>
    <a href="~/Customer" class="btn btn-secondary ms-1">
        <i class="bi bi-arrow-left"></i>
        Quay lại
    </a>
}

<div class="row justify-content-center">
    <div class="col-12">
        <div class="card card-primary card-outline">
            <div class="card-header">
                <h5 class="card-title mb-0">
                    <i class="bi bi-people me-2"></i>
                    Thông tin khách hàng
                </h5>
            </div>

            <div class="card-body">
                <form id="formEdit" method="post" action="/Customer/Save">
                    <input type="hidden" name="CustomerID" value="@Model.CustomerID" />

                    @if (!ViewData.ModelState.IsValid)
                    {
                        <div class="alert alert-danger">
                            <i class="bi bi-exclamation-triangle me-1"></i>
                            Vui lòng kiểm tra lại thông tin nhập liệu
                            <ul class="mb-0 mt-1">
                                @foreach (var state in ViewData.ModelState)
                                {
                                    @foreach (var error in state.Value.Errors)
                                    {
                                        <li>@error.ErrorMessage</li>
                                    }
                                }
                            </ul>
                        </div>
                    }

                    <div class="row align-items-end">
                        <div class="col-md-5 mb-3">
                            <label class="form-label">Tên khách hàng</label>
                            <input type="text"
                                   class="form-control"
                                   name="CustomerName"
                                   value="@Model.CustomerName"
                                   placeholder="Nhập tên khách hàng" autofocus />
                        </div>
                        <div class="col-md-5 mb-3">
                            <label class="form-label">Tên giao dịch</label>
                            <input type="text"
                                   class="form-control"
                                   name="ContactName"
                                   value="@Model.ContactName"
                                   placeholder="Nhập tên giao dịch" />
                        </div>
                        <div class="col-md-2 mb-3">
                            <label class="form-label d-block">Trạng thái</label>
                            <div class="form-check form-switch mt-2">
                                <input class="form-check-input"
                                       type="checkbox"
                                       name="IsLocked"
                                       value="true"
                                       id="IsLocked"
                                       @(Model.IsLocked == true ? "checked" : "") />
                                <label class="form-check-label" for="IsLocked">
                                    Bị khóa
                                </label>
                            </div>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-5 mb-3">
                            <label class="form-label">Điện thoại</label>
                            <input type="tel"
                                   class="form-control"
                                   name="Phone"
                                   value="@Model.Phone"
                                   placeholder="Nhập số điện thoại" />
                        </div>

                        <div class="col-md-7 mb-3">
                            <label class="form-label">Email</label>
                            <input type="email"
                                   class="form-control"
                                   name="Email"
                                   value="@Model.Email"
                                   placeholder="Nhập email" />
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Địa chỉ</label>
                        <textarea class="form-control"
                                  name="Address"
                                  rows="3"
                                  placeholder="Nhập địa chỉ">@Model.Address</textarea>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Tỉnh / Thành</label>
                        <select class="form-select" name="Province">
                            <option value="">-- Chọn tỉnh / thành --</option>
                            @foreach (var p in provinces)
                            {
                                if (Model.Province == p.ProvinceName)
                                {
                                    <option value="@p.ProvinceName" selected>@p.ProvinceName</option>
                                }
                                else
                                {
                                    <option value="@p.ProvinceName">@p.ProvinceName</option>
                                }
                            }
                        </select>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
