@model Category
@{
    ViewBag.Title = "Xóa loại hàng";
}

<div class="card card-danger card-outline">
    <div class="card-header">
        <h3 class="card-title">Xóa loại hàng</h3>
    </div>

    <div class="card-body mt-2">
        <form asp-controller="Category" asp-action="Delete" method="post">
            <input type="hidden" asp-for="CategoryID" />

            <div class="mb-3">
                <label class="form-label text-primary" style="font-weight:bold">Tên loại hàng:</label>
                <p class="form-control-static">@Model.CategoryName</p>
            </div>

            <div class="mb-3">
                <label class="form-label text-primary" style="font-weight:bold">Mô tả:</label>
                <p class="form-control-static">@Model.Description</p>
            </div>

            <div class="card-footer bg-white border-top mt-3 text-end px-0 pb-0 shadow-none border-0">
                @if (TempData["Message"] != null)
                {
                    <div class="alert alert-danger text-start mb-3">
                        @TempData["Message"]
                    </div>
                }
                
                <p class="text-warning text-start mb-3"><strong>Lưu ý:</strong> Hành động này không thể hoàn tác. Bạn có chắc chắn muốn xóa loại hàng này không?</p>
                
                <button type="submit" class="btn btn-danger">
                    <i class="bi bi-trash me-1"></i> Xác nhận xóa
                </button>
                <a href="~/Category" class="btn btn-default">
                    Quay lại
                </a>
            </div>
        </form>
    </div>
</div>


