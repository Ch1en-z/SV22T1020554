@model PagedResult<Category>
@{
    ViewBag.Title = "Quản lý Loại hàng";
}
@section PageToolBar {
    <a href="~/Category/Create" class="btn btn-primary">
        <i class="bi bi-plus-circle me-1"></i>
        Bổ sung
    </a>
}

<div class="card mb-3">
    <div class="card-body">
        <form id="formSearch" action="~/Category" method="get">
            <div class="input-group">
                <input type="text" name="searchValue"
                       class="form-control"
                       placeholder="Nhập tên loại hàng cần tìm" 
                       value="@ViewBag.SearchValue"
                       autofocus />
                <button class="btn btn-info" type="submit">
                    <i class="bi bi-search me-1"></i> Tìm kiếm
                </button>
            </div>
        </form>
    </div>
</div>

<div class="mb-2 text-muted">
    Danh sách có <strong>@Model.RowCount</strong> loại hàng. Trang <strong>@Model.Page / @Model.PageCount</strong>
</div>

<div class="card">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-striped table-hover table-bordered mb-0">
                <thead class="table-secondary">
                    <tr>
                        <th style="width: 250px;">Tên loại hàng</th>
                        <th>Mô tả</th>
                        <th class="text-center" style="width:120px;">Thao tác</th>
                    </tr>
                </thead>
                <tbody class="align-middle">
                    @foreach (var item in Model.DataItems)
                    {
                        <tr>
                             <td>@item.CategoryName</td>
                            <td>@item.Description</td>
                            <td class="text-center">
                                <a href="~/Category/Edit/@item.CategoryID" class="btn btn-sm btn-primary">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                <a href="~/Category/Delete/@item.CategoryID" class="btn btn-sm btn-danger">
                                    <i class="bi bi-trash"></i>
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    @if (Model.PageCount > 1)
    {
        <div class="card-footer">
            <ul class="pagination pagination-sm m-0 justify-content-center">
                @for (int i = 1; i <= Model.PageCount; i++)
                {
                    if (i == Model.Page)
                    {
                        <li class="page-item active"><span class="page-link">@i</span></li>
                    }
                    else
                    {
                        <li class="page-item"><a class="page-link" href="~/Category?page=@i&searchValue=@ViewBag.SearchValue">@i</a></li>
                    }
                }
            </ul>
        </div>
    }
</div>


