@model Category
@{
    ViewBag.Title = "Thiết lập loại hàng";
}

<div class="card card-primary card-outline">
    <div class="card-header">
        <h3 class="card-title">@ViewBag.Title</h3>
    </div>

    <div class="card-body">
        <form asp-controller="Category" asp-action="Save" method="post">
            <div class="form-group mb-3">
                <label class="form-label" style="font-weight:bold">Tên loại hàng:</label>
                <input type="text" class="form-control" name="CategoryName" placeholder="VD: Ống kính Sony" autofocus>
            </div>

            <div class="form-group mb-3">
                <label class="form-label" style="font-weight:bold">Mô tả:</label>
                <textarea class="form-control" name="Description" rows="3" placeholder="Nhập mô tả cho loại hàng này"></textarea>
            </div>

            <div class="card-footer text-end mt-3 px-0 pb-0 bg-transparent border-0">
                <button type="submit" class="btn btn-primary">
                    <i class="bi bi-save me-1"></i> Lưu dữ liệu
                </button>
                <a href="~/Category" class="btn btn-default">
                    Quay lại
                </a>
            </div>
        </form>
    </div>
</div>
