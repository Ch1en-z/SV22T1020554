@model Shipper
@{
    ViewBag.Title = "Đăng ký Người giao hàng";
}

<div class="card card-primary card-outline">
    <div class="card-header">
        <h3 class="card-title">@ViewBag.Title</h3>
    </div>

    <div class="card-body mt-2">
        <form asp-controller="Shipper" asp-action="Save" method="post">
            <div class="row">
                <div class="col-md-12">
                    <div class="mb-3">
                        <label class="form-label" style="font-weight:bold">Tên người giao hàng:</label>
                        <input type="text" class="form-control" name="ShipperName" 
                               placeholder="VD: Viettel Post, Nguyễn Văn A..." 
                               required autofocus />
                    </div>

                    <div class="mb-3">
                        <label class="form-label" style="font-weight:bold">Số điện thoại liên hệ:</label>
                        <input type="tel" class="form-control" name="Phone" 
                               placeholder="09xxxxxxx" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label" style="font-weight:bold">Thông tin bổ sung:</label>
                        <textarea name="Description" class="form-control" rows="3"
                                  placeholder="Các lưu ý về khung giờ giao hàng, bảng giá..."></textarea>
                    </div>
                </div>
            </div>

            <div class="card-footer bg-white border-top mt-3 text-end px-0 pb-0 shadow-none border-0">
                <button type="submit" class="btn btn-primary">
                    <i class="bi bi-save me-1"></i> Lưu thông tin
                </button>
                <a href="~/Shipper" class="btn btn-default">
                    Quay lại
                </a>
            </div>
        </form>
    </div>
</div>
