@{
    ViewBag.Title = "Truy cập bị từ chối";
}

<div class="container-fluid">
    <div class="row">
        <div class="col-12 mt-5 text-center">
            <h1 class="display-1 text-danger fw-bold"><i class="bi bi-exclamation-triangle-fill"></i></h1>
            <h2 class="text-danger fw-bold mt-3">Truy cập bị từ chối</h2>
            <p class="lead mt-3 text-muted">
                Bạn không có quyền truy cập vào chức năng này hoặc tài khoản của bạn chưa được phân quyền.
            </p>
            <p class="text-muted">
                Vui lòng liên hệ với quản trị viên hệ thống để thực hiện yêu cầu này.
            </p>
            <div class="mt-4">
                <a href="~/" class="btn btn-primary shadow-sm">
                    <i class="bi bi-house-door-fill me-1"></i> Quay về trang chủ
                </a>
                <a href="~/Account/Logout" class="btn btn-outline-danger shadow-sm ms-2">
                    <i class="bi bi-box-arrow-right me-1"></i> Đăng xuất
                </a>
            </div>
        </div>
    </div>
</div>
