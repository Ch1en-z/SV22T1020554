@model Product
@{
}

<div class="card card-primary card-outline">
    <div class="card-header">
        <h3 class="card-title">Thông tin mặt hàng</h3>
    </div>

    <div class="card-body">
        <form asp-controller="Product" asp-action="Save" method="post" enctype="multipart/form-data">
            <input type="hidden" asp-for="ProductID" />

            <div class="row mb-3">
                <label class="col-sm-2 col-form-label">Tên mặt hàng:</label>
                <div class="col-sm-10">
                    <input type="text" class="form-control" asp-for="ProductName" autofocus placeholder="Nhập tên mặt hàng">
                    @Html.ValidationMessageFor(m => m.ProductName, "", new { @class = "text-danger" })
                </div>
            </div>

            <div class="row mb-3">
                <label class="col-sm-2 col-form-label">Mô tả tóm tắt:</label>
                <div class="col-sm-10">
                    <textarea class="form-control" rows="3" asp-for="ProductDescription" placeholder="Nhập mô tả chi tiết về sản phẩm này"></textarea>
                </div>
            </div>

            <div class="row mb-3">
                <label class="col-sm-2 col-form-label">Loại hàng:</label>
                <div class="col-sm-4">
                    <select class="form-select" asp-for="CategoryID">
                        <option value="0">-- Chọn loại hàng --</option>
                        @foreach (var c in ViewBag.Categories)
                        {
                            <option value="@c.CategoryID">@c.CategoryName</option>
                        }
                    </select>
                    @Html.ValidationMessageFor(m => m.CategoryID, "", new { @class = "text-danger" })
                </div>

                <label class="col-sm-2 col-form-label text-end">Nhà cung cấp:</label>
                <div class="col-sm-4">
                    <select class="form-select" asp-for="SupplierID">
                        <option value="0">-- Chọn nhà cung cấp --</option>
                        @foreach (var s in ViewBag.Suppliers)
                        {
                            <option value="@s.SupplierID">@s.SupplierName</option>
                        }
                    </select>
                    @Html.ValidationMessageFor(m => m.SupplierID, "", new { @class = "text-danger" })
                </div>
            </div>

            <div class="row mb-3">
                <label class="col-sm-2 col-form-label">Đơn vị tính:</label>
                <div class="col-sm-4">
                    <input type="text" class="form-control" asp-for="Unit" placeholder="Ví dụ: Cái, Bộ, Kg...">
                    @Html.ValidationMessageFor(m => m.Unit, "", new { @class = "text-danger" })
                </div>

                <label class="col-sm-2 col-form-label text-end">Giá bán:</label>
                <div class="col-sm-4">
                    <input type="text" class="form-control money-input" name="priceInput" value="@Model.Price.ToString("N0")" placeholder="0">
                </div>
            </div>

            <div class="row mb-3">
                <label class="col-sm-2 col-form-label">Trạng thái:</label>
                <div class="col-sm-10">
                    <div class="form-check form-switch mt-2">
                        <input class="form-check-input" type="checkbox" asp-for="IsSelling" id="IsSelling">
                        <label class="form-check-label" for="IsSelling">Mặt hàng này đang được bán</label>
                    </div>
                </div>
            </div>

            <div class="row mb-3">
                <label class="col-sm-2 col-form-label">Ảnh minh họa:</label>
                <div class="col-sm-10">
                    <input type="file" name="uploadPhoto" class="form-control mb-2" accept="image/*"
                           onchange="document.getElementById('imgPreview').src = window.URL.createObjectURL(this.files[0])" />
                    <input type="hidden" asp-for="Photo" />
                    <img id="imgPreview"
                         src="~/images/products/@(string.IsNullOrEmpty(Model.Photo) ? "noproduct.png" : Model.Photo)"
                         class="img-fluid rounded border"
                         style="max-height: 250px" />
                </div>
            </div>

            <div class="card-footer text-end">
                <button type="submit" class="btn btn-primary">
                    <i class="bi bi-save me-1"></i> Lưu dữ liệu
                </button>
                <a href="~/Product" class="btn btn-default">
                    Quay lại
                </a>
            </div>
            <div asp-validation-summary="ModelOnly" class="text-danger mt-2"></div>
        </form>
    </div>
</div>

@if (Model.ProductID > 0)
{
    await Html.RenderPartialAsync("ListPhotos", (List<ProductPhoto>)ViewBag.Photos);
    await Html.RenderPartialAsync("ListAttributes", (List<ProductAttribute>)ViewBag.Attributes);
}


