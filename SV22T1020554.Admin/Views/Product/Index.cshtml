@model PagedResult<Product>
@{
    ViewBag.Title = "Quản lý Mặt hàng";
    var searchInput = ViewBag.SearchInput as ProductSearchInput ?? new ProductSearchInput();
}
@section PageToolBar {
    <a href="~/Product/Create" class="btn btn-primary">
        <i class="bi bi-plus-circle me-1"></i>
        Bổ sung
    </a>
}

@if (TempData["Message"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="bi bi-check-circle-fill me-2"></i>
        @Html.Raw(TempData["Message"])
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="card mb-3">
    <div class="card-body">
        <form id="formSearch" action="~/Product" method="get">
            <div class="row g-2">
                <div class="col-md-3">
                    <label class="form-label">Loại hàng</label>
                    <select name="categoryID" class="form-select">
                        <option value="0">-- Tất cả --</option>
                        @foreach (var c in ViewBag.Categories)
                        {
                            if (c.CategoryID == searchInput.CategoryID)
                            {
                                <option value="@c.CategoryID" selected>@c.CategoryName</option>
                            }
                            else
                            {
                                <option value="@c.CategoryID">@c.CategoryName</option>
                            }
                        }
                    </select>
                </div>

                <div class="col-md-3">
                    <label class="form-label">Nhà cung cấp</label>
                    <select name="supplierID" class="form-select">
                        <option value="0">-- Tất cả --</option>
                        @foreach (var s in ViewBag.Suppliers)
                        {
                            if (s.SupplierID == searchInput.SupplierID)
                            {
                                <option value="@s.SupplierID" selected>@s.SupplierName</option>
                            }
                            else
                            {
                                <option value="@s.SupplierID">@s.SupplierName</option>
                            }
                        }
                    </select>
                </div>

                <div class="col-md-3">
                    <label class="form-label">Khoảng giá</label>
                    <div class="input-group">
                        <input type="text" name="minPrice" class="form-control" placeholder="Từ" value="@searchInput.MinPrice" />
                        <span class="input-group-text">-</span>
                        <input type="text" name="maxPrice" class="form-control" placeholder="Đến" value="@searchInput.MaxPrice" />
                    </div>
                </div>

                <div class="col-md-3">
                    <label class="form-label">Tên mặt hàng</label>
                    <div class="input-group">
                        <input type="text" name="searchValue" class="form-control" placeholder="Tên mặt hàng..." value="@searchInput.SearchValue" autofocus />
                        <button class="btn btn-info" type="submit">
                            <i class="bi bi-search me-1"></i> Tìm
                        </button>
                    </div>
                </div>
            </div>
        </form>
    </div>
</div>

<div class="mb-2 text-muted">
    Danh sách có <strong>@Model.RowCount</strong> mặt hàng. Trang <strong>@Model.Page / @Model.PageCount</strong>
</div>

<div class="card mb-5">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-striped table-hover table-bordered mb-0">
                <thead class="table-secondary">
                    <tr>
                        <th style="width:80px;" class="text-center">Ảnh</th>
                        <th>Thông tin mặt hàng</th>
                        <th style="width:120px;" class="text-center">Đơn vị</th>
                        <th style="width:140px;" class="text-center">Giá bán</th>
                        <th class="text-center" style="width:140px;">Trạng thái</th>
                        <th class="text-center" style="width:120px;">Thao tác</th>
                    </tr>
                </thead>
                <tbody class="align-middle">
                    @foreach (var item in Model.DataItems)
                    {
                        <tr>
                            <td class="text-center">
                                <img src="~/images/products/@(string.IsNullOrEmpty(item.Photo) ? "noproduct.png" : item.Photo)"
                                     class="rounded border"
                                     style="width: 50px; height: 50px; object-fit: cover;"
                                     alt="@item.ProductName" />
                            </td>
                            <td>
                                 <div>@item.ProductName</div>
                                <div class="text-muted small">@item.ProductDescription</div>
                            </td>
                            <td class="text-center">@item.Unit</td>
                            <td class="text-end pe-3">@item.Price.ToString("N0") VNĐ</td>
                            <td class="text-center">
                                @if (item.IsSelling == true)
                                {
                                    <span class="badge bg-success">Đang bán</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">Ngừng bán</span>
                                }
                            </td>
                            <td class="text-center text-nowrap">
                                <a href="~/Product/Edit/@item.ProductID" class="btn btn-sm btn-primary">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                <a href="~/Product/Delete/@item.ProductID" class="btn btn-sm btn-danger">
                                    <i class="bi bi-trash"></i>
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    @if (Model.PageCount > 1)
    {
        <div class="card-footer">
            <ul class="pagination pagination-sm m-0 justify-content-center">
                @for (int i = 1; i <= Model.PageCount; i++)
                {
                    if (i == Model.Page)
                    {
                        <li class="page-item active"><span class="page-link">@i</span></li>
                    }
                    else
                    {
                        <li class="page-item"><a class="page-link" href="~/Product?page=@i&searchValue=@searchInput.SearchValue&categoryID=@searchInput.CategoryID&supplierID=@searchInput.SupplierID&minPrice=@searchInput.MinPrice&maxPrice=@searchInput.MaxPrice">@i</a></li>
                    }
                }
            </ul>
        </div>
    }
</div>


