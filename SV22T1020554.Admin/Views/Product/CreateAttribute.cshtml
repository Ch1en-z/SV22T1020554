<div class="card card-primary card-outline">
    <div class="card-header">
        <h3 class="card-title">@ViewBag.Title</h3>
    </div>
    <div class="card-body">
        <form action="~/Product/SaveAttribute" method="post">
            <input type="hidden" name="ProductID" value="@ViewBag.ProductID" />
            <input type="hidden" name="AttributeID" value="@ViewBag.AttributeID" />

            <div class="form-group mb-3">
                <label class="form-label" style="font-weight:bold">Tên thuộc tính:</label>
                <input type="text" name="AttributeName" class="form-control" placeholder="VD: Kích thước, Trọng lượng..." required autofocus>
            </div>

            <div class="form-group mb-3">
                <label class="form-label" style="font-weight:bold">Giá trị:</label>
                <input type="text" name="AttributeValue" class="form-control" placeholder="VD: XL, 500g..." required>
            </div>

            <div class="form-group mb-3">
                <label class="form-label" style="font-weight:bold">Thứ tự hiển thị:</label>
                <input type="number" name="DisplayOrder" class="form-control" value="1">
            </div>

            <div class="card-footer text-end mt-3 px-0 pb-0 bg-transparent border-0">
                <button type="submit" class="btn btn-primary">
                    <i class="bi bi-save me-1"></i> Lưu dữ liệu
                </button>
                <a href="~/Product/Edit/@ViewBag.ProductID" class="btn btn-default">Hủy bỏ</a>
            </div>
        </form>
    </div>
</div>
