<div class="card card-primary card-outline">
    <div class="card-header">
        <h3 class="card-title">Thêm mặt hàng mới</h3>
    </div>

    <form asp-controller="Product" asp-action="Create" method="post" enctype="multipart/form-data">
        <div class="card-body">
            <div class="row">
                <div class="col-md-9">
                    <div class="form-group mb-3">
                        <label class="form-label" style="font-weight:bold">Tên mặt hàng:</label>
                        <input type="text" class="form-control" name="ProductName" required autofocus>
                    </div>

                    <div class="row">
                        <div class="col-md-6 form-group mb-3">
                            <label class="form-label" style="font-weight:bold">Danh mục:</label>
                            <select class="form-select" name="CategoryID">
                                <option value="">-- Chọn danh mục --</option>
                                <option value="1">Máy ảnh</option>
                                <option value="2">Ống kính</option>
                            </select>
                        </div>
                        <div class="col-md-6 form-group mb-3">
                            <label class="form-label" style="font-weight:bold">Nhà cung cấp:</label>
                            <select class="form-select" name="SupplierID">
                                <option value="">-- Chọn nhà cung cấp --</option>
                                <option value="1">Sony Việt Nam</option>
                            </select>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6 form-group mb-3">
                            <label class="form-label" style="font-weight:bold">Đơn vị tính:</label>
                            <input type="text" class="form-control" name="Unit" placeholder="Cái, Chiếc, Bộ...">
                        </div>
                        <div class="col-md-6 form-group mb-3">
                            <label class="form-label" style="font-weight:bold">Giá mặt hàng:</label>
                            <input type="number" class="form-control" name="Price" min="0">
                        </div>
                    </div>
                </div>

                <div class="col-md-3">
                    <div class="form-group mb-3">
                        <label class="form-label" style="font-weight:bold">Ảnh minh họa:</label>
                        <input type="file" class="form-control mb-2" name="uploadPhoto"
                               onchange="document.getElementById('PhotoPreview').src = window.URL.createObjectURL(this.files[0])">
                        <div class="text-center border rounded p-2 bg-light">
                            <img id="PhotoPreview" src="~/images/products/no-image.png"
                                 class="img-fluid" style="max-height: 200px;" alt="Preview">
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="card-footer text-end mt-3 px-0 pb-0 bg-transparent border-0">
            <button type="submit" class="btn btn-primary">
                <i class="bi bi-save me-1"></i> Lưu dữ liệu
            </button>
            <a href="~/Product" class="btn btn-default">Quay lại</a>
        </div>
    </form>
</div>
