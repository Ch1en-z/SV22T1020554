@model IEnumerable<ProductAttribute>
@{
    Layout = null;
}
<div class="row">
    <div class="col-12">
        <div class="card card-success card-outline mt-4">
            <div class="card-header">
                <h3 class="card-title">Đặc tính kỹ thuật của mặt hàng</h3>
                <div class="card-tools">
                    <a class="btn btn-sm btn-primary" href="~/Product/Attribute/@ViewContext.RouteData.Values["id"]?method=add">
                        <i class="bi bi-plus"></i> Thêm đặc tính
                    </a>
                </div>
            </div>

            <div class="card-body p-0">
                <table class="table table-bordered table-hover table-striped mb-0">
                    <thead class="table-secondary">
                        <tr>
                            <th style="width: 200px;">Tên đặc tính</th>
                            <th>Giá trị đặc tính</th>
                            <th style="width: 100px" class="text-center">Thứ tự</th>
                            <th style="width: 100px" class="text-center">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody class="align-middle">
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="text-primary" style="font-weight:bold;">@item.AttributeName</td>
                                <td>@item.AttributeValue</td>
                                <td class="text-center">@item.DisplayOrder</td>
                                <td class="text-center text-nowrap">
                                    <a class="btn btn-xs btn-primary" 
                                       href="~/Product/Attribute/@item.ProductID?method=edit&attributeId=@item.AttributeID">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                    <a class="btn btn-xs btn-danger" 
                                       href="~/Product/Attribute/@item.ProductID?method=delete&attributeId=@item.AttributeID" 
                                       onclick="return confirm('Xóa đặc tính này của mặt hàng?')">
                                        <i class="bi bi-trash"></i>
                                    </a>
                                </td>
                            </tr>
                        }
                        @if (!Model.Any())
                        {
                            <tr>
                                <td colspan="4" class="text-center text-muted py-3">
                                    Sản phẩm này chưa có đặc tính kỹ thuật nào.
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>


