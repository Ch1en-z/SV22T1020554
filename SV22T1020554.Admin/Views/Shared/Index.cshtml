@{
    ViewBag.Title = "Trang chủ";
}

<div class="row pt-3">
    <div class="col-lg-3 col-6">
        <div class="small-box bg-primary shadow-sm">
            <div class="inner">
                <p>Doanh thu hôm nay</p>
                <h3>12.500.000 đ</h3>
            </div>
            <div class="icon"><i class="bi bi-currency-dollar"></i></div>
        </div>
    </div>
    <div class="col-lg-3 col-6">
        <div class="small-box bg-success shadow-sm">
            <div class="inner">
                <p>Đơn hàng</p>
                <h3>48</h3>
            </div>
            <div class="icon"><i class="bi bi-cart-check-fill"></i></div>
        </div>
    </div>
    <div class="col-lg-3 col-6">
        <div class="small-box bg-warning shadow-sm">
            <div class="inner">
                <p>Khách hàng</p>
                <h3>320</h3>
            </div>
            <div class="icon"><i class="bi bi-people-fill text-white-50"></i></div>
        </div>
    </div>
    <div class="col-lg-3 col-6">
        <div class="small-box bg-danger shadow-sm">
            <div class="inner">
                <p>Sản phẩm</p>
                <h3>128</h3>
            </div>
            <div class="icon"><i class="bi bi-box-seam-fill"></i></div>
        </div>
    </div>
</div>

<div class="row mt-4">
    <div class="col-lg-8 mb-4">
        <div class="card h-100 shadow-sm">
            <div class="card-header border-0 bg-transparent">
                <h3 class="card-title text-muted fw-bold">
                    <i class="bi bi-bar-chart-fill me-2 text-primary"></i> Doanh thu theo tháng
                </h3>
            </div>
            <div class="card-body">
                <canvas id="revenue-chart" style="height: 300px; width: 100%;"></canvas>
            </div>
        </div>
    </div>
    <div class="col-lg-4 mb-4">
        <div class="card h-100 shadow-sm">
            <div class="card-header border-0 bg-transparent">
                <h3 class="card-title text-muted fw-bold">
                    <i class="bi bi-star-fill me-2 text-warning"></i> Top sản phẩm bán chạy
                </h3>
            </div>
            <div class="card-body p-0 mt-2">
                <div class="list-group list-group-flush">
                    <div class="list-group-item d-flex justify-content-between align-items-center border-0 px-4 py-3">
                        <span class="text-secondary"><i class="bi bi-laptop me-2"></i> Laptop Dell</span>
                        <span class="badge bg-success rounded-pill px-3">120</span>
                    </div>
                    <div class="list-group-item d-flex justify-content-between align-items-center border-0 px-4 py-3">
                        <span class="text-secondary"><i class="bi bi-phone me-2"></i> iPhone 15</span>
                        <span class="badge bg-success rounded-pill px-3">98</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row mt-2">
    <div class="col-12">
        <div class="card shadow-sm border-0">
            <div class="card-header bg-white py-3">
                <h3 class="card-title text-muted fw-bold mb-0">
                    <i class="bi bi-clock-history me-2 text-info"></i> Đơn hàng cần xử lý
                </h3>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover mb-0 align-middle">
                        <thead class="table-light">
                            <tr>
                                <th class="ps-4 py-3">Mã đơn</th>
                                <th>Khách hàng</th>
                                <th>Ngày</th>
                                <th class="text-end">Tổng tiền</th>
                                <th class="text-center">Trạng thái</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td class="ps-4">#DH00125</td>
                                <td class="fw-bold">Nguyễn Văn A</td>
                                <td class="text-muted">01/02/2026</td>
                                <td class="text-end fw-bold text-dark">3.500.000 đ</td>
                                <td class="text-center"><span class="badge bg-danger px-3 py-2">Đang chờ duyệt</span></td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const ctx = document.getElementById('revenue-chart').getContext('2d');
            new Chart(ctx, {
                type: 'bar',
                data: {
                    labels: ['Tháng 1', 'Tháng 2', 'Tháng 3', 'Tháng 4', 'Tháng 5', 'Tháng 6'],
                    datasets: [{
                        label: 'Doanh thu (triệu đồng)',
                        data: [120, 150, 180, 100, 160, 210],
                        backgroundColor: '#3b82f6',
                        borderRadius: 6
                    }]
                },
                options: {
                    maintainAspectRatio: false,
                    responsive: true
                }
            });
        });
    </script>
}