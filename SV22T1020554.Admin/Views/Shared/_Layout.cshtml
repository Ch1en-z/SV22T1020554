<!doctype html>
<html lang="en">
<head>
    <meta http-equiv="Content-Type" content="text/html; charset=utf-8" />
    <title>BHQCShop - Admin</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=yes" />
    <link rel="stylesheet" href="~/lib/flatpickr/flatpickr.min.css">    
    <link rel="stylesheet" href="~/lib/bootstrap/bootstrap-icons.min.css" />    
    <link rel="stylesheet" href="~/lib/adminlte/css/adminlte.css" />
    <link rel="stylesheet" href="~/css/site.css" />
    @await RenderSectionAsync("Styles", required: false)
</head>
<body class="sidebar-expand-lg sidebar-open bg-body-tertiary">
    <div class="app-wrapper">
        @await Html.PartialAsync("_Header")
        @await Html.PartialAsync("_Sidebar")        
        <main class="app-main">
            <div class="app-content-header">
                <div class="container-fluid">
                    <div class="row align-items-center">
                        <div class="col-sm-6">
                            <h5 class="mb-0">@ViewBag.Title</h5>
                        </div>
                        <div class="col-sm-6">
                            <div class="d-flex justify-content-end gap-1">
                                @await RenderSectionAsync("PageToolBar", required: false)
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="app-content">
                <div class="container-fluid">
                    @RenderBody()
                </div>
            </div>
        </main>
        @await Html.PartialAsync("_Footer")        
    </div>

    <script src="~/lib/jquery/jquery.min.js"></script>
    <script src="~/lib/flatpickr/flatpickr.min.js"></script>
    <script src="~/lib/flatpickr/l10n/vn.js"></script>    
    <script src="~/lib/autonumeric/autonumeric.js"></script>    
    <script src="~/lib/bootstrap/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script type="module" src="~/lib/adminlte/js/adminlte.js"></script>
    <script src="~/js/site.js"></script>
    <script>
        document.addEventListener("DOMContentLoaded", function () {            
            if (typeof flatpickr !== 'undefined') {
                flatpickr(".date-picker", {
                    dateFormat: "d/m/Y",
                    locale: "vn",
                    allowInput: false
                });
            }
            if (typeof AutoNumeric !== 'undefined') {
                document.querySelectorAll(".money-input").forEach(element => {
                    new AutoNumeric(element, {
                        digitGroupSeparator: '.',
                        decimalCharacter: ',',
                        decimalPlaces: 0,
                        unformatOnSubmit: true
                    });
                });
            }
        });
    </script>
    @await RenderSectionAsync("Scripts", required: false)

    <!-- Modal dùng chung cho toàn hệ thống -->
    <div class="modal fade" id="dialogModal" tabindex="-1" role="dialog" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content shadow-lg border-0">
                <!-- Nội dung modal sẽ được load tại đây -->
            </div>
        </div>
    </div>

    <script>
        $(document).ready(function () {
            // Tự động gán sự kiện click cho các phần tử có class open-modal
            $(document).on("click", ".open-modal", function (e) {
                if (typeof openModal === "function") {
                    openModal(e, this);
                }
            });
        });
    </script>
</body>
</html>